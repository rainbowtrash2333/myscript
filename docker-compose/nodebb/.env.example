# 复制本文件为 .env 后再修改; docker compose 会自动加载 .env
# 所有 changeme 占位符都必须改成强密码

# ----- NodeBB -----
# 浏览器访问地址 (含端口, 反代时填外网域名)
NODEBB_URL=http://localhost:4567
# 宿主机端口 -> 容器 4567
NODEBB_HOST_PORT=4567
# NodeBB 源码分支或 tag, 留空走 Dockerfile 默认 v4.x
NODEBB_VERSION=v4.x

# ----- 管理员 -----
ADMIN_USER=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=changeme-admin-strong-password

# ----- MongoDB root (mongo 镜像初始化用) -----
MONGO_ROOT_USER=root
MONGO_ROOT_PASS=changeme-root-strong-password

# ----- MongoDB NodeBB 业务账号 -----
MONGO_USER=nodebb
MONGO_PASS=changeme-nodebb-strong-password
MONGO_DB=nodebb
